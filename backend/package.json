{
  "name": "days4fitness-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "node src/db/migrate.js",
    "migrate:test": "node src/db/migrate-test.js",
    "test": "node --test --test-isolation=none test/api-conventions.test.js test/clients.service.test.js test/configuration.service.test.js",
    "test:integration": "npm run migrate:test && node --test --test-isolation=none test/clients.integration.test.js",
    "test:all": "npm test && npm run test:integration",
    "check": "node --check src/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
