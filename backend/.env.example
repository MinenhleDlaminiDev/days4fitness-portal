NODE_ENV=development
PORT=5000
BUSINESS_TIMEZONE=Africa/Johannesburg
CORS_ORIGINS=http://localhost:5173

# Option 1: single URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/days4fitness
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/days4fitness_test

# Option 2: separate values (used if DATABASE_URL is missing)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=days4fitness
DB_USER=postgres
DB_PASSWORD=postgres

# Local trainer bootstrap account. Change these before production.
TRAINER_BOOTSTRAP_EMAIL=trainer@days4fitness.local
TRAINER_BOOTSTRAP_NAME=Days4Fitness Trainer
TRAINER_BOOTSTRAP_PASSWORD=ChangeMe123!
AUTH_SESSION_HOURS=12

# Google OAuth client ID for trainer Google sign-in.
GOOGLE_CLIENT_ID=

# Production hardening
REQUEST_BODY_LIMIT=100kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=30
TRUST_PROXY=false
